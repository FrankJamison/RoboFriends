{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install + dev",
      "type": "shell",
      "command": "npm install && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Open in Browser (robofriends.localhost)",
      "type": "shell",
      "command": "start \"\" http://robofriends.localhost:5173/",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open in Browser",
            "type": "shell",
            "command": "start",
            "args": [
                "chrome",
                "http://robofriends.localhost/"
            ],
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
